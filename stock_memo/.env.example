# === Anthropic API キー ===
# https://console.anthropic.com で取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Notion API ===
# https://www.notion.so/my-integrations でトークンを取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
# NotionデータベースのURL末尾のID (32文字)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 設定 ===
# 監視するXアカウント (デフォルト: shodousan)
TARGET_USERNAME=shodousan

# 1回の実行で取得するポスト数
MAX_TWEETS=20

# メモの保存先ディレクトリ
NOTES_DIR=notes
