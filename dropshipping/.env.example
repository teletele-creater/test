# ====================================
# 無在庫転売管理ツール 環境設定
# ====================================
# このファイルをコピーして .env として保存してください
# cp .env.example .env

# --- Discord通知（Webhook URL） ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# --- LINE Messaging API通知 ---
# ※ LINE Notifyは2025年3月末で廃止されました。
#    LINE Developers (https://developers.line.biz/) でBotを作成し、
#    Messaging APIのチャネルアクセストークンとユーザーIDを取得してください。
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_USER_ID=your-line-user-id

# --- 通知方法: "discord", "line", "both" ---
NOTIFICATION_METHOD=discord

# --- メルカリログイン情報（フェーズ3で使用） ---
MERCARI_EMAIL=your-email@example.com
MERCARI_PASSWORD=your-password
