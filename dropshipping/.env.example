# ====================================
# 無在庫転売管理ツール 環境設定
# ====================================
# このファイルをコピーして .env として保存してください
# cp .env.example .env

# --- Discord通知（Webhook URL） ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# --- LINE Notify通知 ---
LINE_NOTIFY_TOKEN=your-line-notify-token

# --- 通知方法: "discord", "line", "both" ---
NOTIFICATION_METHOD=discord

# --- メルカリログイン情報（フェーズ3で使用） ---
MERCARI_EMAIL=your-email@example.com
MERCARI_PASSWORD=your-password
